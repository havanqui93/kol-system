# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/kol_system"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Primary LLM — Claude (preferred)
ANTHROPIC_API_KEY="sk-ant-..."

# Fallback LLM — OpenAI (also used for Whisper subtitles)
OPENAI_API_KEY="sk-..."

# TTS — ElevenLabs (Vietnamese voice support)
ELEVENLABS_API_KEY="..."

# Video — Kling via fal.ai
FAL_API_KEY="..."

# ─── Storage — Cloudflare R2 ──────────────────────────────────────────────────
R2_ACCOUNT_ID="..."
AWS_ACCESS_KEY_ID="..."        # R2 API token access key
AWS_SECRET_ACCESS_KEY="..."    # R2 API token secret
S3_BUCKET="kol-assets"
R2_PUBLIC_URL="https://pub-XXXX.r2.dev"  # optional: public bucket URL

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Social Publishing (V2) ───────────────────────────────────────────────────
# TIKTOK_CLIENT_KEY=""
# TIKTOK_CLIENT_SECRET=""
# FACEBOOK_APP_ID=""
# FACEBOOK_APP_SECRET=""
