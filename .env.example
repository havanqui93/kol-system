# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/kol_system"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Primary LLM — Claude (preferred)
ANTHROPIC_API_KEY="sk-ant-..."

# Fallback LLM — OpenAI (also used for Whisper subtitles)
OPENAI_API_KEY="sk-..."

# TTS — ElevenLabs (Vietnamese voice support)
ELEVENLABS_API_KEY="..."

# Video — Kling via fal.ai (note: FAL_KEY not FAL_API_KEY)
FAL_KEY="..."

# ─── Storage — Cloudflare R2 ──────────────────────────────────────────────────
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."         # R2 API token access key
R2_SECRET_ACCESS_KEY="..."     # R2 API token secret
R2_BUCKET_NAME="kol-assets"
R2_PUBLIC_URL="https://pub-XXXX.r2.dev"  # optional: public bucket URL

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Worker Concurrency (optional — defaults shown) ───────────────────────────
WORKER_CONCURRENCY_SCRIPT=3
WORKER_CONCURRENCY_AUDIO=5
WORKER_CONCURRENCY_KLING=2
WORKER_CONCURRENCY_RENDER=2
WORKER_CONCURRENCY_PUBLISH=3

# ─── Social Publishing ────────────────────────────────────────────────────────
# TIKTOK_CLIENT_KEY=""
# TIKTOK_CLIENT_SECRET=""
# FACEBOOK_APP_ID=""
# FACEBOOK_APP_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
